[Unit]
Description=SOVD simulated DoIP ECU
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sovd_user
WorkingDirectory=/home/sovd_user/sovd_practice
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStart=/usr/bin/python3 -u /home/sovd_user/sovd_practice/doip_ecu.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
